# =============================================================================
# OilanAI — env variables (Gemini API)
# =============================================================================
# Скопируй этот файл как ".env" и заполни значения.
# Бесплатный ключ Gemini: https://aistudio.google.com/apikey
# =============================================================================

# --- Вариант A: быстрый (ключ в браузере) ----------------------------------
# Используется для локальной разработки (npm run dev) и простых деплоев.
# ВНИМАНИЕ: этот ключ будет виден в JS-бандле. Не используй в продакшене.
VITE_GEMINI_API_KEY=

# Модель Gemini (опционально). По умолчанию gemini-flash-latest.
# Рекомендованные варианты:
#   gemini-flash-latest       - указывает на свежую flash, большая квота (default)
#   gemini-2.5-flash-lite     - очень большая квота на free tier
#   gemini-flash-lite-latest  - то же, алиас
#   gemini-2.0-flash          - стабильная, без thinking-overhead
#   gemini-2.5-flash          - 20 RPD на free tier (мало!), но высокое качество
#   gemini-2.5-pro            - максимальное качество, очень маленький free tier
VITE_GEMINI_MODEL=gemini-flash-latest

# --- Вариант B: безопасный (ключ на сервере) ------------------------------
# Используется на деплое через Vercel / Netlify.
# Эта переменная НЕ попадает в браузер (нет префикса VITE_).
# Настраивается в dashboard хостинга, не в этом файле.
#GEMINI_API_KEY=
#GEMINI_MODEL=gemini-2.5-flash
